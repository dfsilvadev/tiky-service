{
  "name": "tiky-service",
  "version": "1.0.0",
  "description": "Backend API para o Tiky: Um gerenciador de tarefas gamificado com sistema de XP, loja de recompensas e ofensiva diária.",
  "main": "index.js",
  "scripts": {
    "start:dev": "tsx watch src/server.ts",
    "start": "node build/server.cjs",
    "test": "vitest run",
    "test:dev": "vitest",
    "test:unit": "vitest run --project unit",
    "test:unit:dev": "vitest --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:dev": "vitest --project e2e",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build": "tsup src --out-dir build --format cjs --clean",
    "type:check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "bcryptjs": "3.0.3",
    "dayjs": "1.11.19",
    "dotenv": "17.3.1",
    "fastify": "5.8.2",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.38.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "25.3.5",
    "@types/pg": "8.18.0",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.46.2",
    "@typescript-eslint/parser": "8.46.2",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.4.0",
    "@vitest/ui": "4.0.6",
    "eslint": "9.38.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "16.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "prettier": "^3.8.1",
    "prisma": "7.4.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  }
}
