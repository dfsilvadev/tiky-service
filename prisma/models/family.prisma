model Family {
  id          String       @id @default(uuid())
  name        String
  description String?
  status      FamilyStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relacionamentos
  accounts  Account[]
  templates TaskTemplate[] @relation("FamilyTemplates")

  @@map("families")
}
