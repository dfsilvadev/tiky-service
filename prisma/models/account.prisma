model Account {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role
  xpBalance     Int      @default(0)
  currentStreak Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  sessions            Session[]
  taskTemplates       TaskTemplate[]       @relation("Author")
  taskInstances       TaskInstance[]       @relation("Player")
  redemptionRequests  RedemptionRequest[]
  transactions        Transaction[]

  @@map("accounts")
}