model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  isRevoked    Boolean  @default(false)
  expiresAt    DateTime
  
  createdAt    DateTime @default(now())

  user         Account     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}