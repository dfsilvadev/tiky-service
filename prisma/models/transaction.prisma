model Transaction {
  id          String          @id @default(uuid())
  playerId    String
  type        TransactionType
  amount      Int             // Positivo ou Negativo dependendo do type
  description String
  
  createdAt   DateTime        @default(now())

  player      Account            @relation(fields: [playerId], references: [id])

  @@index([playerId, createdAt(sort: Desc)])
  @@map("transactions")
}