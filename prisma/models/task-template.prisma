model TaskTemplate {
  id                String         @id @default(uuid())
  authorId          String
  title             String
  description       String?
  baseXp            Int
  weight            Weight
  isMandatory       Boolean        @default(true)
  
  recurrenceType    RecurrenceType
  recurrencePattern String?        // Ex: "1,3,5" para WEEKLY ou "4" para INTERVAL
  scheduledFor      DateTime?      @db.Date
  timeLimit         String?        // Ex: "18:00"
  
  status            TemplateStatus @default(ACTIVE)
  subtasks          String[]       // Array de textos para tarefas EPIC
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  author            Account           @relation("Author", fields: [authorId], references: [id])
  instances         TaskInstance[]

  @@index([status])
  @@index([authorId])
  @@map("task_templates")
}