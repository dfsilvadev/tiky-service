model TaskTemplate {
  id        String @id @default(uuid())
  accountId String
  familyId  String

  title       String
  description String?
  baseXp      Int
  weight      Weight
  isMandatory Boolean @default(true)

  recurrenceType    RecurrenceType
  recurrencePattern String? // Ex: "1,3,5" para WEEKLY ou "4" para INTERVAL
  scheduledFor      DateTime?      @db.Date
  timeLimit         String? // Ex: "18:00"

  status   TemplateStatus @default(ACTIVE)
  subtasks String[] // Array de textos para tarefas EPIC

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  account   Account        @relation("AccountTemplates", fields: [accountId], references: [id])
  family    Family         @relation("FamilyTemplates", fields: [familyId], references: [id])
  instances TaskInstance[]

  @@index([status])
  @@index([accountId])
  @@index([familyId])
  @@map("task_templates")
}
