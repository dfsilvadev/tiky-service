#!/usr/bin/env sh

echo "🔍 Verificando tipos TypeScript..."
pnpm run type:check

if [ $? -ne 0 ]; then
  echo "❌ Type check error. Fix before pushing."
  exit 1
fi

echo "✅ Type check passed!"

echo "🧪 Executando testes..."
pnpm run test

if [ $? -ne 0 ]; then
  echo "❌ Testes falharam. Corrija antes do push."
  exit 1
fi

echo "✅ Testes passaram!"

